# 🛡️ Entropy Server Configuration (Rust)
# ALL variables below are MANDATORY. The server will panic if any are missing.

# Network
ENTROPY_ADDR=127.0.0.1
ENTROPY_PORT=8080

# TLS
ENTROPY_ENABLE_TLS=false
ENTROPY_CERT_PATH=certs/server.crt
ENTROPY_KEY_PATH=certs/server.key

# Redis
ENTROPY_REDIS_URL=redis://127.0.0.1:6379
ENTROPY_REDIS_PASSWORD=
ENTROPY_REDIS_USERNAME=

# Resource Limits
ENTROPY_MAX_MSG_SIZE=65536    # Reassembled support (64 KB)
ENTROPY_MAX_GLOBAL_CONNS=100000
ENTROPY_CONN_TIMEOUT=60
ENTROPY_WS_PING_INTERVAL=0   # Disabled (Stealth Dummy pacing used instead)
ENTROPY_SESSION_TTL=2592000   # 30 days

# Rate Limiting
ENTROPY_RATE_LIMIT=1000.0
ENTROPY_RATE_BURST=10000
ENTROPY_LIMIT_GLOBAL=10000
ENTROPY_LIMIT_KEYS_UPLOAD=10
ENTROPY_LIMIT_KEYS_FETCH=50
ENTROPY_LIMIT_RELAY=5000
ENTROPY_LIMIT_NICK_REGISTER=5
ENTROPY_LIMIT_NICK_LOOKUP=30
ENTROPY_LIMIT_ACCOUNT_BURN=3

# Protocol Defaults
ENTROPY_MAX_NICK_LEN=32
ENTROPY_MAX_PREKEYS=100
ENTROPY_POW_DIFF=500000
ENTROPY_POW_BASE=100000
ENTROPY_MAX_JSON_DEPTH=12
ENTROPY_MAX_OFFLINE_MSGS=200

# Traffic Pacing
ENTROPY_PACING_IDLE=5000
ENTROPY_PACING_SIZE=16384
ENTROPY_PACING_TICK=500

# Security (CRITICAL)
ENTROPY_ADMIN_TOKEN=CHANGE_IN_PROD
ENTROPY_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:1420

# VDF (Hardened Proof-of-Work)
ENTROPY_VDF_
ENTROPY_VDF_PHI=KEEP_THIS_SECRET_FOR_O1_VERIFICATION
