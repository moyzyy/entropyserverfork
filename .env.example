# ALL variables below are MANDATORY. The server will panic if any are missing.

# Network
ENTROPY_ADDR=127.0.0.1
ENTROPY_PORT=8080

# Redis
ENTROPY_REDIS_URL=redis://127.0.0.1:6379
ENTROPY_REDIS_PASSWORD=
ENTROPY_REDIS_USERNAME=

# Resource Limits
ENTROPY_MAX_MSG_SIZE=256000  # 256 KB
ENTROPY_MAX_GLOBAL_CONNS=100000
ENTROPY_CONN_TIMEOUT=60
ENTROPY_SESSION_TTL=2592000   # 30 days
ENTROPY_OFFLINE_TTL=604800    # 7 days

# Rate Limiting
ENTROPY_RELAY_WINDOW=60        # Message throughput window (sec)
ENTROPY_KEYS_WINDOW=3600       # Key rotation window (sec)
ENTROPY_LIMIT_KEYS_UPLOAD=10
ENTROPY_LIMIT_RELAY=60
ENTROPY_LIMIT_NICK_REGISTER=5
ENTROPY_VIOL_THRESHOLD=10
ENTROPY_JAIL_TTL=300            # Actual ban duration (sec)
ENTROPY_VIOL_RESET=3600         # Violation history persistence (sec)

# Protocol Defaults
ENTROPY_MAX_NICK_LEN=32
ENTROPY_MAX_PREKEYS=100
ENTROPY_POW_DIFF=5000000
ENTROPY_POW_BASE=500000
ENTROPY_MAX_JSON_DEPTH=8
ENTROPY_MAX_OFFLINE_MSGS=500
ENTROPY_MAX_OFFLINE_PER_SENDER=15

# Traffic Pacing
ENTROPY_PACING_SIZE=1400

# Security (CRITICAL)
ENTROPY_ADMIN_TOKEN=CHANGE_THIS_TO_A_LONG_SECURE_TOKEN

# VDF (Hardened Proof-of-Work)
# MODULUS is public, but should be unique per server deployment (RSA-2048 N)
ENTROPY_VDF_MODULUS=GENERATE_NEW_RSA_2048_MODULUS
# PHI is the SECRET (Euler's totient). If leaked, anyone can bypass PoW.
ENTROPY_VDF_PHI=KEEP_THIS_SECRET_AND_NEVER_COMMIT_TO_GIT


ENTROPY_DB_SALT="A_LONG_RANDOM_SECRET_STRING_HERE"
